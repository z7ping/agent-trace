{
  "name": "agent-trace",
  "version": "1.8.1",
  "description": "实时监控和可视化 Claude Code、Hermes、Codex、OpenCode 等 AI 编码工具的调用记录，多工具统一追踪，按会话分组展示。",
  "main": "server/cli.js",
  "bin": {
    "agent-beat": "./server/cli.js"
  },
  "scripts": {
    "dev": "vite --port 5173",
    "dev:frontend": "vite --port 5173",
    "build": "vite build",
    "start": "node server/cli.js start",
    "stop": "node server/cli.js stop",
    "status": "node server/cli.js status",
    "install-hooks": "node server/cli.js install",
    "package": "node server/cli.js package",
    "prepublishOnly": "vite build"
  },
  "files": [
    "dist/",
    "server/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitea.7ping.site/ai-area/agent-beat.git"
  },
  "keywords": ["claude-code", "ai-tools", "monitoring", "visualization", "agent"],
  "author": "",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "chart.js": "^4.5.1",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0",
    "sql.js": "^1.11.0"
  }
}
