{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/tooltrace/prelog.js",
            "type": "command",
            "timeout": 5,
            "statusMessage": "",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/tooltrace/log.js",
            "type": "command",
            "timeout": 10,
            "statusMessage": "",
            "async": false
          }
        ]
      }
    ]
  }
}
